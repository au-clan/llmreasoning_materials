\[
\frac{1}{2} \omega_e = \frac{1}{2} \times 1405.65 = 702.825  \text{cm}^{-1}
\]
\[
\frac{1}{4} \omega_e x_e = \frac{1}{4} \times 23.20 = 5.800  \text{cm}^{-1}
\]
\[
\text{Zero-point energy} = 702.825 - 5.800 = 697.025  \text{cm}^{-1}
\]

