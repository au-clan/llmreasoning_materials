def find_solution(nums):
    # brute force all possible equations
    from itertools import permutations, product

    operators = ['+', '-', '*', '/']

    for p in permutations(nums):
        for ops in product(operators, repeat=3):
            equation = f"(({p[0]} {ops[0]} {p[1]}) {ops[1]} {p[2]}) {ops[2]} {p[3]}"
            try:
                if round(eval(equation), 5) == 24:
                    return equation + " = 24"
            except ZeroDivisionError:
                pass

            equation = f"({p[0]} {ops[0]} ({p[1]} {ops[1]} {p[2]})) {ops[2]} {p[3]}"
            try:
                if round(eval(equation), 5) == 24:
                    return equation + " = 24"
            except ZeroDivisionError:
                pass

            equation = f"{p[0]} {ops[0]} (({p[1]} {ops[1]} {p[2]}) {ops[2]} {p[3]})"
            try:
                if round(eval(equation), 5) == 24:
                    return equation + " = 24"
            except ZeroDivisionError:
                pass

            equation = f"{p[0]} {ops[0]} ({p[1]} {ops[1]} ({p[2]} {ops[2]} {p[3]}))"
            try:
                if round(eval(equation), 5) == 24:
                    return equation + " = 24"
            except ZeroDivisionError:
                pass

    return "No solution"

nums = [1, 5, 9, 13]
print(find_solution(nums))
