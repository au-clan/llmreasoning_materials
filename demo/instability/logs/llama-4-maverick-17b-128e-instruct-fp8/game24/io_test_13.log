                    remaining_nums = [nums[k] for k in range(len(nums)) if k != i and k != j]
                    a, b = nums[i], nums[j]
                    remaining_nums.append(a + b)
                    if dfs(remaining_nums):
                        return True
                    remaining_nums[-1] = a - b
                    if dfs(remaining_nums):
